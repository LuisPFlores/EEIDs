# ---------------------------------------------------------------------------
# WS-Federation test app configuration
# ---------------------------------------------------------------------------

# App
PORT=3001
SESSION_SECRET=change-this-wsfed-session-secret

# WS-Fed Realm — the identifier (entity ID) for this relying party.
# Must match the Identifier URI configured in the Entra app registration.
WSFED_REALM=http://localhost:3001

# WS-Fed Reply URL — where Entra posts the signed token after sign-in.
# Must match the Reply URL configured in the Entra app registration.
WSFED_REPLY_URL=http://localhost:3001/auth/callback

# Entra IdP WS-Federation endpoint
WSFED_IDP_URL=https://login.microsoftonline.com/<TENANT_ID>/wsfed

# IdP issuer (usually the STS URL)
WSFED_IDP_ISSUER=https://sts.windows.net/<TENANT_ID>/

# Paste the Base64 X.509 certificate body (single line), not thumbprint.
WSFED_IDP_CERT=MIIC...base64-x509-without-PEM-headers...

# Tenant ID (used for logout URL)
TENANT_ID=<your-tenant-id>
