# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# Entra External ID (CIAM) — from scripts/CIAM/Register-CIAMApp.ps1 output
TENANT_NAME=<your-ciam-tenant-subdomain>
TENANT_ID=<your-external-tenant-id>
CLIENT_ID=<your-app-client-id>
CLIENT_SECRET=<your-app-client-secret>

# Must match the redirect URI registered in the Entra app registration
REDIRECT_URI=http://localhost:3000/auth/redirect

# Name of the CIAM user flow created by New-CIAMUserFlow.ps1
USER_FLOW=B2C_1_SignUpSignIn

# Random secret for signing the Express session cookie
SESSION_SECRET=replace-with-a-long-random-string

# Google reCAPTCHA v2 — from https://www.google.com/recaptcha/admin
RECAPTCHA_SITE_KEY=<your-recaptcha-site-key>
RECAPTCHA_SECRET=<your-recaptcha-secret-key>

# Set to "production" when deployed
NODE_ENV=development
