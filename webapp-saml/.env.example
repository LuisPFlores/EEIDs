# ---------------------------------------------------------------------------
# SAML 2.0 test app configuration
# ---------------------------------------------------------------------------

# App
PORT=3002
SESSION_SECRET=change-this-saml-session-secret

# Service Provider (this app)
SAML_SP_ENTITY_ID=http://localhost:3002/metadata.xml
SAML_CALLBACK_URL=http://localhost:3002/auth/callback

# IdP configuration (Option A: explicit values)
SAML_IDP_ENTRY_POINT=https://idp.example.com/sso/saml
SAML_IDP_ISSUER=https://idp.example.com/entity-id
SAML_IDP_CERT=MIIC...base64-x509-without-PEM-headers...

# IdP configuration (Option B: metadata URL fallback)
# If Option A values are not set, app attempts to resolve from metadata URL.
SAML_IDP_METADATA_URL=https://idp.example.com/metadata
